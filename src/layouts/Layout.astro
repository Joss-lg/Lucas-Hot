---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ParticlesManager from '../components/ParticlesManager.jsx';


interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Lucas Hot Family - Snacks & Drinks en Valle de Chalco" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Bangers&family=Montserrat:wght@400;700;900&display=swap" rel="stylesheet">
	</head>
	
	<body class="lucas-bg text-white font-body flex flex-col min-h-screen">
		<ParticlesManager client:load />
		<Header />

		<main class="flex-grow">
			<slot />
		</main>

		<Footer />

	</body>
</html>

<style is:global>
	/* Tipografía */
	h1, h2, h3, h4, .font-display {
		font-family: 'Bangers', cursive;
		letter-spacing: 0.05em;
	}
    
    /* Scrollbar personalizada */
    ::-webkit-scrollbar {
        width: 10px;
    }
    ::-webkit-scrollbar-track {
        background: #090052;
    }
    ::-webkit-scrollbar-thumb {
        background: #400062;
        border-radius: 5px;
    }
    ::-webkit-scrollbar-thumb:hover {
        background: #FF00C7;
    }

    /* --- EL NUEVO FONDO ESTILO 'AURORA' --- */
    .lucas-bg {
        background-color: #090052; /* Color base (Azul oscuro) */
        /* Aquí creamos 3 "focos" de luz mezclados:
           1. Arriba izquierda: Tu Morado (#400062)
           2. Arriba derecha/centro: Tu Rosa Neón (#FF00C7) para el brillo fuerte
           3. Abajo: El Azul profundo (#090052)
        */
        background-image: 
            radial-gradient(at 0% 0%, #400062 0px, transparent 50%),
            radial-gradient(at 100% 0%, #FF00C7 0px, transparent 40%),
            radial-gradient(at 50% 100%, #090052 0px, transparent 50%);
        
        background-attachment: fixed; /* Esto hace que el fondo se quede quieto al bajar */
        background-size: cover;
        background-repeat: no-repeat;
    }
</style>