---
import Layout from '../layouts/Layout.astro';
import Location from '../components/Location.astro';
import { menuCategories } from '../data/menu.js';
---

<Layout title="Lucas Hot Family | El Sabor Rebelde">

    {/* SECCIÓN HERO / HEADER (Se mantiene igual) */}
    <header class="relative min-h-[80vh] flex items-center justify-center overflow-hidden pt-48">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,_var(--tw-gradient-stops))] from-lucas-purple via-lucas-dark to-black opacity-95 z-10"></div>
        
        <div class="absolute top-20 right-10 w-80 h-80 bg-lucas-pink rounded-full mix-blend-screen filter blur-[120px] opacity-20 animate-pulse"></div>
        <div class="absolute bottom-10 left-10 w-80 h-80 bg-blue-600 rounded-full mix-blend-screen filter blur-[120px] opacity-20"></div>

        <div class="relative z-20 text-center px-4 max-w-6xl mx-auto mt-10">
            <h2 class="text-lucas-pink font-bold tracking-[0.5em] mb-8 text-sm md:text-xl uppercase animate-bounce">
                📍 Valle de Chalco
            </h2>
            <h1 class="text-7xl md:text-9xl font-display text-white leading-[0.9] drop-shadow-[0_5px_0px_rgba(64,0,98,1)] transform -rotate-2">
                FAMILY SNACKS <br /> 
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-lucas-pink to-purple-400 filter drop-shadow-[0_0_15px_rgba(255,0,199,0.5)]"> & DRINKS</span>
            </h1>
            <p class="mt-10 text-xl md:text-2xl text-gray-200 max-w-3xl mx-auto font-medium border-y border-lucas-pink/30 py-6">
                Rompe la rutina con el sabor más <span class="text-lucas-pink font-bold">HOT</span> y el mejor ambiente familiar.
            </p>
            
            <div class="mt-12 flex justify-center gap-4">
                <a href="#menu-start" class="bg-lucas-pink text-white font-bold py-4 px-10 rounded-full hover:bg-white hover:text-lucas-pink transition-all shadow-[0_0_30px_rgba(255,0,199,0.4)] hover:shadow-none transform hover:-translate-y-1">
                    👇 Ver Menú
                </a>
            </div>
        </div>
    </header>

    {/* SECCIÓN MENÚ RENOVADA (Código nuevo insertado aquí) */}
    <div id="menu-start" class="bg-[#050014] relative z-20 pb-24">
        
        {/* Fondos ambientales nuevos */}
        <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
            <div class="absolute top-[10%] left-[-10%] w-[40rem] h-[40rem] bg-lucas-purple rounded-full mix-blend-screen filter blur-[150px] opacity-20"></div>
            <div class="absolute bottom-[20%] right-[-10%] w-[30rem] h-[30rem] bg-lucas-fire rounded-full mix-blend-screen filter blur-[150px] opacity-10"></div>
        </div>

        <div class="container mx-auto px-4 py-20 relative z-10">
            
            <div class="text-center mb-20">
                <h2 class="text-5xl md:text-7xl text-white mb-4 drop-shadow-lg">
                    NUESTRO <span class="text-transparent bg-clip-text bg-gradient-to-r from-lucas-pink to-lucas-fire">MENÚ</span>
                </h2>
                <div class="h-1 w-24 bg-gradient-to-r from-lucas-pink to-lucas-fire mx-auto rounded-full"></div>
                <p class="text-gray-400 mt-6 text-lg font-light tracking-wide max-w-2xl mx-auto">
                    Explora nuestras especialidades preparadas al momento. <br>
                    <span class="text-lucas-fire font-bold">¡Cuidado, quema! 🔥</span>
                </p>
            </div>

            {menuCategories.map((category) => (
                <section id={category.id} class="mb-24 scroll-mt-32">
                    
                    <div class="flex items-end gap-4 mb-10 border-b border-gray-800 pb-4">
                        <h3 class="text-4xl md:text-5xl font-display text-white uppercase tracking-wide flex items-center gap-3">
                            <span class="text-lucas-fire">{category.icon}</span> 
                            {category.title}
                        </h3>
                        {category.note && (
                            <span class="hidden md:inline-block text-xs font-bold text-gray-500 bg-gray-900 px-3 py-1 rounded-full border border-gray-800 mb-2">
                                {category.note}
                            </span>
                        )}
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        {category.items.map((item) => (
                            <div class={`relative group p-6 rounded-xl transition-all duration-300 border hover:-translate-y-1 
                                ${item.highlight 
                                    ? 'bg-gradient-to-br from-lucas-purple/40 to-black border-lucas-pink shadow-[0_0_30px_rgba(255,0,199,0.15)] md:col-span-2 lg:col-span-2' 
                                    : 'bg-gradient-to-br from-[#120B2E] to-[#080418] border-gray-800 hover:border-lucas-fire/50 hover:shadow-[0_0_20px_rgba(255,77,0,0.15)]'
                                }`}>
                                
                                {/* Etiqueta Destacado */}
                                {item.highlight && (
                                    <div class="absolute -top-3 -right-3 bg-lucas-pink text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg border border-white/20 animate-pulse">
                                        ★ FAVORITO
                                    </div>
                                )}

                                <div class="flex justify-between items-start gap-4 mb-3">
                                    <h4 class={`font-display text-white leading-tight ${item.highlight ? 'text-3xl' : 'text-xl group-hover:text-lucas-pink transition-colors'}`}>
                                        {item.name}
                                    </h4>
                                    
                                    <div class={`font-display text-lg px-3 py-1 rounded-lg shadow-sm whitespace-nowrap
                                        ${item.highlight 
                                            ? 'bg-lucas-fire text-white rotate-2' 
                                            : 'bg-[#1F1440] text-lucas-pink group-hover:bg-lucas-pink group-hover:text-white transition-colors'
                                        }`}>
                                        {item.price}
                                    </div>
                                </div>
                                
                                <p class="text-gray-400 text-sm md:text-base leading-relaxed font-body group-hover:text-gray-300 transition-colors">
                                    {item.desc}
                                </p>

                                {/* Barra decorativa inferior */}
                                <div class={`absolute bottom-0 left-4 right-4 h-[2px] rounded-full transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500
                                    ${item.highlight ? 'bg-lucas-pink' : 'bg-lucas-fire'}`}>
                                </div>
                            </div>
                        ))}
                    </div>
                </section>
            ))}
        </div>
    </div>

    <Location />

</Layout>